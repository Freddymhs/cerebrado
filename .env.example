# El provider activo se selecciona desde el dropdown en la UI (localStorage).
# No se configura aquí.

# ─────────────────────────────────────────────────────────────────────────────
# GEMINI
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash       # otros: gemini-1.5-pro, gemini-1.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# OPENAI
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini            # otros: gpt-4o, gpt-4-turbo
OPENAI_WHISPER_MODEL=whisper-1      # modelo de transcripción de audio

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA (local)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream              # modelo vision (analiza imágenes de pantalla)
OLLAMA_TEXT_MODEL=moondream         # modelo texto (si difiere del vision, ej: qwen3.5:0.8b)

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# Debe coincidir con una clave en PROVIDER_RATE_LIMITS (src/constants/analysis.ts)
# Opciones: gemini_free | gemini_paid | openai_tier1 | openai_tier2 | ollama
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AI_PROVIDER_TIER=gemini_free

# ─────────────────────────────────────────────────────────────────────────────
# ANÁLISIS
# Intervalo en ms. El intervalo real = MAX(este valor, mínimo seguro del provider)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ANALYSIS_INTERVAL_MS=3000

# ─────────────────────────────────────────────────────────────────────────────
# AUDIO (modo Entrevista)
# Selector en UI guarda preferencia en localStorage.
# local: apunta a faster-whisper, whisper.cpp u otro endpoint compatible.
# ─────────────────────────────────────────────────────────────────────────────
LOCAL_TRANSCRIBE_URL=http://localhost:8080/transcribe
